{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/example.json",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60
    },
    "amount": {
      "type": "number",
      "minimum": 0
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 200
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "category": {
      "type": ["string", "null"],
      "maxLength": 50
    },
    "budget": {
      "type": ["string", "null"],
      "maxLength": 50
    }
  },
  "additionalProperties": false,
  "required": ["name", "amount", "date"]
}
