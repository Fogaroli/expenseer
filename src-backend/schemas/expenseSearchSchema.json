{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/example.json",
  "type": "object",
  "properties": {
    "limit": {
      "type": "number",
      "minimum": 1,
      "maximum": 100
    },
    "offset": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "category": {
      "type": "string",
      "maxLength": 50
    },
    "budget_name": {
      "type": "string",
      "maxLength": 50
    }
  },
  "additionalProperties": false,
  "required": []
}
